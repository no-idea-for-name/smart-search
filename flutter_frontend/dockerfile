# Step 1: Build the Flutter web app
FROM cirrusci/flutter:stable AS builder

# Set the working directory
WORKDIR /app

# Copy the Flutter project files into the container
COPY . .

# Get Flutter dependencies
RUN flutter pub get

# Build the Flutter app for the web
RUN flutter build web

# Step 2: Set up Nginx to serve the app
FROM nginx:alpine

# Copy the Flutter web build files into Nginx's HTML directory
COPY --from=builder /app/build/web /usr/share/nginx/html

# Expose port 80 to access the app through Nginx
EXPOSE 80

# Start Nginx when the container runs
CMD ["nginx", "-g", "daemon off;"]
